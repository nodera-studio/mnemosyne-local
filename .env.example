# Copy to .env on the box. Secrets are generated there with `make secrets`
# (openssl) so they never leave the server. Never commit .env.

POSTGRES_DB=mnemosyne
POSTGRES_USER=mnemo
POSTGRES_PASSWORD=__generate_on_box__
REDIS_PASSWORD=__generate_on_box__

# --- Voyage AI (embeddings + rerank for memory-mcp + codebase-mcp) ---
# REQUIRED — both services refuse to start without it (assertServerConfig).
VOYAGE_API_KEY=__set_on_box__
# Code embedder model for codebase-mcp. Default voyage-code-3; the Wave 5 bake-off may flip
# this to voyage-context-3. Re-embedding the corpus after a change is a deliberate ops action
# (truncate+reindex) — never auto-run on deploy (it costs Voyage quota).
VOYAGE_CODE_MODEL=voyage-code-3
# Contextual CODE embedder for the Wave 5 bake-off arm (codebase-mcp embedCodeContextual()).
# Default voyage-context-3 (GA). The bake-off re-embeds into the scratch embedding_ctx column
# (npm run bakeoff) — a deliberate paid ops action, never auto-run; live search is unaffected.
VOYAGE_CODE_CONTEXT_MODEL=voyage-context-3
# Legacy memory embedder (memory-mcp embed() path + importer/distill scripts). Default
# voyage-4-large. Kept during the Wave-P burn-in so a rollback stays possible.
VOYAGE_EMBED_MODEL=voyage-4-large
# Contextual memory embedder: voyage-context-4 is HARD-PINNED in compose.yaml (coupled
# to the embedding_v2 column contents — a per-box override would silently mismatch the
# query-vs-corpus embedders). This line is documentation only; setting it has no effect.
# The re-embed backfill (npm run backfill:context) is a deliberate ops action, never auto-run.
VOYAGE_CONTEXT_MODEL=voyage-context-4

# --- Langfuse v2 (eval plane) — secrets generated on box by `make secrets` ---
LANGFUSE_DB=langfuse
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
LANGFUSE_NEXTAUTH_SECRET=__generate_on_box__
LANGFUSE_SALT=__generate_on_box__
LANGFUSE_ENCRYPTION_KEY=__generate_on_box__          # openssl rand -hex 32 (64 hex chars)
LANGFUSE_INIT_ORG_ID=mnemosyne
LANGFUSE_INIT_PROJECT_ID=mnemosyne-evals
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-__generate_on_box__
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-__generate_on_box__
LANGFUSE_INIT_USER_EMAIL=dev@example.com
LANGFUSE_INIT_USER_PASSWORD=__generate_on_box__
LANGFUSE_INIT_USER_NAME=Mnemosyne

# --- Local-only ---
# No remote ingress — memory/codebase/secrets MCP are loopback-only, reached directly
# by Claude Code running on this machine. Leave ALLOWED_ORIGINS unset unless you're
# fronting these services with something else on your LAN.
ALLOWED_ORIGINS=

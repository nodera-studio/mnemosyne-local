# secrets — generated on the box, never committed
.env
secrets/

# node
node_modules/
dist/
*.tsbuildinfo

# logs / scratch
*.log
.DS_Store

# claude code worktrees + local agent scratch (worktrees live here)
.claude/

# db dumps / canonical tarballs
backups/

